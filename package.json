{
  "name": "contexgin",
  "version": "0.1.0",
  "description": "Context orchestration engine for AI agent harnesses",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dimakis/contexgin.git"
  },
  "keywords": [
    "context",
    "ai",
    "agent",
    "llm",
    "orchestration"
  ],
  "bin": {
    "contexgin": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "check": "tsc --noEmit",
    "prepare": "npm run build && husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.4",
    "ignore": "^7.0.5",
    "yaml": "^2.8.3"
  }
}
